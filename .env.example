# ── Forensic Flight AI — environment configuration reference ──────────────────
#
# Copy to .env and fill in values for your deployment target.
# All values shown are the defaults (what you get if the variable is omitted).
#
# NEVER commit .env to version control.
# In production, supply secrets via Secrets Manager / Parameter Store / Vault.
# ─────────────────────────────────────────────────────────────────────────────

# ── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_ROOT=/home/<user>/.forensic_flight

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://forensic:forensic@localhost:5432/forensic_flight
DATABASE_URL_SYNC=postgresql+psycopg2://forensic:forensic@localhost:5432/forensic_flight

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_URL=redis://localhost:6379/1
REDIS_PUBSUB_URL=redis://localhost:6379/2

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# CORS_ORIGINS=["http://localhost:3000","https://app.example.com"]


# =============================================================================
# INFERENCE CONFIGURATION
# =============================================================================
#
# Three deployment profiles.  Uncomment the block that matches your target.
#
# Agent routing:
#   DOMAIN tier  → EKFDiagnosticsAgent, GPSIntegrityAgent, PowerSystemAgent,
#                  VibrationAnalysisAgent  (fast_model, high volume)
#   CRITICAL tier → CrashInvestigatorAgent, ReportWriterAgent
#                  (primary_model, safety-critical synthesis)
#   EMBED         → ComparativeAnalystAgent (embed() only)
#   NONE          → FlightTimelineAgent, ESCMotorAgent, FlightDynamicsAgent,
#                   MissionBehaviorAgent, ParameterDriftAgent, SafetyComplianceAgent
#
# See config/routing.py for the complete agent-to-tier mapping.
# =============================================================================


# ── Profile A: Local Ollama (default — no API keys required) ─────────────────
#
# Best for: development, air-gapped environments, privacy-critical deployments.
# Requires: Ollama running locally with the models pulled.
#
INFERENCE_MODE=ollama
DOMAIN_PROVIDER=ollama
DOMAIN_MODEL=qwen3:8b-q4_K_M
CRITICAL_PROVIDER=ollama
CRITICAL_MODEL=qwen3:32b-q4_K_M
FALLBACK_PROVIDER=ollama
FALLBACK_MODEL=qwen3:32b-q4_K_M

OLLAMA_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen3:32b-q4_K_M
OLLAMA_FAST_MODEL=qwen3:8b-q4_K_M
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5
# OLLAMA_TIMEOUT_SECONDS=1200   # 20 min — CPU inference is slow; raise for larger models


# ── Profile B: Managed cloud APIs (AWS/SaaS production) ──────────────────────
#
# Best for: SaaS deployment, fastest time-to-value, predictable scaling.
# Requires: Anthropic + OpenAI API keys (from Secrets Manager in production).
# Break-even vs self-hosted 70B HA pair: ~2,000–2,200 investigations/day.
#
# INFERENCE_MODE=api
# DOMAIN_PROVIDER=openai
# DOMAIN_MODEL=gpt-4o-mini-2024-07-18
# CRITICAL_PROVIDER=anthropic
# CRITICAL_MODEL=claude-sonnet-4-6
# FALLBACK_PROVIDER=openai
# FALLBACK_MODEL=gpt-4o-2024-11-20
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# ANTHROPIC_API_KEY=sk-ant-api03-...   # NEVER hard-code; use Secrets Manager
# OPENAI_API_KEY=sk-...                # NEVER hard-code; use Secrets Manager
# INFERENCE_REQUEST_TIMEOUT_SECONDS=120


# ── Profile C: Hybrid (domain=OpenAI, critical=Anthropic, fallback=Ollama) ───
#
# Best for: cost-optimised SaaS — cheap domain calls via GPT-4o-mini,
# high-quality critical path via Claude, local Ollama as cost-free fallback.
#
# INFERENCE_MODE=hybrid
# DOMAIN_PROVIDER=openai
# DOMAIN_MODEL=gpt-4o-mini-2024-07-18
# CRITICAL_PROVIDER=anthropic
# CRITICAL_MODEL=claude-sonnet-4-6
# FALLBACK_PROVIDER=ollama
# FALLBACK_MODEL=qwen3:32b-q4_K_M
#
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...
# INFERENCE_REQUEST_TIMEOUT_SECONDS=120


# ── Profile D: Self-hosted vLLM (enterprise on-prem / GPU cluster) ────────────
#
# Best for: enterprise/defense, data-sovereignty, >2,000 investigations/day.
# Requires: vLLM endpoint serving a 70B model (e.g. Llama-3.3-70B-Instruct).
#
# INFERENCE_MODE=hybrid
# DOMAIN_PROVIDER=vllm
# DOMAIN_MODEL=meta-llama/Llama-3.3-70B-Instruct
# CRITICAL_PROVIDER=vllm
# CRITICAL_MODEL=meta-llama/Llama-3.3-70B-Instruct
# FALLBACK_PROVIDER=ollama
# FALLBACK_MODEL=qwen3:32b-q4_K_M
#
# VLLM_ENDPOINT=http://vllm-internal:8000
# VLLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
# VLLM_CONCURRENCY_LIMIT=4   # tune to GPU memory and batch size


# ── Miscellaneous inference tuning ────────────────────────────────────────────
# INFERENCE_REQUEST_TIMEOUT_SECONDS=120

# ── Investigation tuning ──────────────────────────────────────────────────────
# MAX_INVESTIGATION_ITERATIONS=5
# HYPOTHESIS_CONFIDENCE_THRESHOLD=0.70
# AGENT_TIMEOUT_SECONDS=600
