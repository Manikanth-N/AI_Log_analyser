# ─────────────────────────────────────────────
# Forensic Flight AI — environment variables
# Copy to .env and adjust for your setup
# ─────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+psycopg2://forensic:forensic@localhost:5432/forensic_flight

# Redis (Celery broker + pubsub)
REDIS_URL=redis://localhost:6379/0
REDIS_PUBSUB_URL=redis://localhost:6379/1

# Qdrant vector DB
QDRANT_URL=http://localhost:6333

# Ollama inference
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen3:32b-q4_K_M
OLLAMA_FAST_MODEL=qwen3:8b-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# Storage paths (defaults to ~/.forensic_flight — override with absolute path if needed)
# STORAGE_ROOT=/data/forensic_flight

# Upload limits
MAX_UPLOAD_SIZE_MB=6144

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Investigation
MAX_INVESTIGATION_ITERATIONS=3
